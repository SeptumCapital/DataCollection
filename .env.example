# Required by SEC fair-access guidance. Use a real contact email.
SEC_USER_AGENT="SenQuantDataCollection/0.1 your.email@example.com"

# Required only for Alpha Vantage endpoints.
ALPHA_VANTAGE_API_KEY=""

# Optional: override where downloaded data is stored.
DATA_COLLECTION_ROOT="./data"

# Optional: used by scripts/sync_render_data.sh to upload local data to Render.
RENDER_SSH_TARGET="srv-xxxxx@ssh.virginia.render.com"
RENDER_DATA_ROOT="/var/data/senquant"
